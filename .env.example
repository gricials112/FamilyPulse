DB_PASSWORD=change_me_strong_password
FAMILYPULSE_ADMIN_TOKEN=change_me_admin_token
FAMILYPULSE_APPLE_CLIENT_ID=com.lwj.FamilyPulse
FAMILYPULSE_SUBSCRIPTION_PRODUCT_IDS=com.lwj.FamilyPulse.premium.monthly.v2,com.lwj.FamilyPulse.premium.yearly.v2
FAMILYPULSE_SEED_TEST_ACCOUNTS=true
FAMILYPULSE_RATE_LIMIT_MAX_REQUESTS=10
FAMILYPULSE_GOMEMLIMIT=96MiB
FAMILYPULSE_GOGC=80

# 微信开放平台配置（如需微信登录）
WECHAT_APP_ID=wxYOUR_APP_ID_HERE
WECHAT_APP_SECRET=YOUR_APP_SECRET_HERE

# Apple Push Notification service（订阅用户 Push 通知）
FAMILYPULSE_APNS_ENABLED=false
FAMILYPULSE_APNS_TOPIC=com.lwj.FamilyPulse
FAMILYPULSE_APNS_TEAM_ID=YOUR_APPLE_TEAM_ID
FAMILYPULSE_APNS_KEY_ID=YOUR_APNS_KEY_ID
# 可填单行 \n 转义后的 .p8 内容，或在部署平台配置多行环境变量。
FAMILYPULSE_APNS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
